# ── Required ──────────────────────────────────────
BOT_TOKEN=paste_your_bot_token_here
CLIENT_ID=your_bot_application_id   # found on the General Information page in the developer portal
GUILD_ID=your_server_id

# ── Voice Channel (pick one or both) ─────────────
# Auto-join this channel on bot startup:
AUTO_JOIN_CHANNEL_ID=your_voice_channel_id

# Auto-follow this user into any voice channel:
OWNER_USER_ID=your_discord_user_id

# ── AI Model ──────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.2:3b

# ── Whisper.cpp ────────────────────────────────────
WHISPER_BIN=/home/youruser/whisper.cpp/main
WHISPER_MODEL=/home/youruser/whisper.cpp/models/ggml-base.en.bin

# ── Piper TTS ──────────────────────────────────────
PIPER_BIN=/home/youruser/piper/piper
PIPER_MODEL=/home/youruser/piper/voices/en_US-lessac-medium.onnx

# ── Optional: Custom system prompt ────────────────
# SYSTEM_PROMPT=You are a helpful assistant...
